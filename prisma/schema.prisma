// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  clerk_id          String?  @unique
  email             String   @unique
  name              String
  username          String   @unique
  verified          Boolean  @default(false)
  password          String
  verification_code    Int
  verification_expires DateTime?
  profile              Profile?
  expenses             Expense[]
  splits               ExpenseSplit[]
  group_memberships    GroupMember[]
  settlements_made     Settlement[]    @relation("SettlementPayer")
  settlements_received Settlement[]    @relation("SettlementReceiver")
  recurring_expenses   RecurringExpense[]
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  @@index([email, username])
}

model Category {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  icon       String?
  color      String?
  expenses   Expense[]
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
}

model Expense {
  id           Int            @id @default(autoincrement())
  title        String
  amount       Decimal        @db.Decimal(12, 2)
  date         DateTime       @default(now())
  user_id      Int
  category_id  Int
  group_id     Int?
  description  String?
  is_recurring     Boolean           @default(false)
  recurrence       String? // daily, weekly, monthly, yearly
  recurring_id     Int?
  user             User              @relation(fields: [user_id], references: [id])
  category         Category          @relation(fields: [category_id], references: [id])
  group            Group?            @relation(fields: [group_id], references: [id])
  recurring_source RecurringExpense? @relation(fields: [recurring_id], references: [id])
  splits           ExpenseSplit[]
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  @@index([user_id])
  @@index([category_id])
  @@index([group_id])
  @@index([recurring_id])
  @@index([date])
}

model RecurringExpense {
  id              Int       @id @default(autoincrement())
  title           String
  amount          Decimal   @db.Decimal(12, 2)
  user_id         Int
  category_id     Int
  group_id        Int?
  frequency       String // daily, weekly, monthly, yearly
  start_date      DateTime  @default(now())
  end_date        DateTime?
  next_run        DateTime?
  last_run        DateTime?
  active          Boolean   @default(true)
  user            User      @relation(fields: [user_id], references: [id])
  generated_expenses Expense[]
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@index([user_id])
  @@index([next_run])
}


model Group {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  owner_id    Int
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  @@index([owner_id])
}

model GroupMember {
  id         Int      @id @default(autoincrement())
  group_id   Int
  user_id    Int
  group      Group    @relation(fields: [group_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])
  created_at DateTime @default(now())

  @@unique([group_id, user_id])
}

model ExpenseSplit {
  id         Int      @id @default(autoincrement())
  expense_id Int
  user_id    Int
  amount     Decimal  @db.Decimal(12, 2)
  expense    Expense  @relation(fields: [expense_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])
  created_at DateTime @default(now())

  @@index([expense_id])
  @@index([user_id])
}

model Settlement {
  id          Int      @id @default(autoincrement())
  group_id    Int
  payer_id    Int
  receiver_id Int
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @default(now())
  group       Group    @relation(fields: [group_id], references: [id])
  payer       User     @relation("SettlementPayer", fields: [payer_id], references: [id])
  receiver    User     @relation("SettlementReceiver", fields: [receiver_id], references: [id])

  @@index([group_id])
  @@index([payer_id])
  @@index([receiver_id])
}


model Profile {
  id              Int      @id @default(autoincrement())
  user_id         Int      @unique
  avatar_url      String?
  avatar_filename String?
  avatar_color    String
  user            User     @relation(fields: [user_id], references: [id])
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([user_id])
}
