{
	"name": "flowledger-server",
	"version": "1.0.0",
	"description": "Expense managing application backend",
	"main": "dist/index.js",
	"scripts": {
		"build": "yarn install --frozen-lockfile && prisma generate --schema ./prisma/schema.prisma && DATABASE_URL=$DIRECT_URL prisma migrate deploy --schema ./prisma/schema.prisma && tsc && tsc-alias",
		"start": "prisma migrate deploy --schema ./prisma/schema.prisma && node dist/index.js",
		"dev": "tsx watch src/index.ts",
		"docs": "echo 'No docs build configured'",
		"lint": "eslint \"src/**/*.ts\" --fix",
		"format": "prettier --write \"src/**/*.ts\"",
		"prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
		"prisma:migrate": "prisma migrate dev --schema ./prisma/schema.prisma",
		"prisma:studio": "prisma studio --schema ./prisma/schema.prisma"
	},
	"dependencies": {
		"@clerk/express": "^2.1.14",
		"@prisma/client": "^5.22.0",
		"@supabase/supabase-js": "^2.45.0",
		"cors": "^2.8.5",
		"dotenv": "^16.1.4",
		"express": "^4.18.2",
		"helmet": "^7.1.0",
		"module-alias": "^2.3.4",
		"multer": "^1.4.5-lts.1",
		"node-cron": "^4.2.1",
		"prisma": "^5.22.0",
		"random-material-color": "^1.0.5",
		"resend": "^6.12.3",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1",
		"tsc-alias": "^1.8.17",
		"typescript": "^5.9.3",
		"zod": "^3.22.2"
	},
	"devDependencies": {
		"@types/cors": "^2.8.13",
		"@types/express": "^4.17.25",
		"@types/multer": "^1.4.7",
		"@types/node": "^20.19.39",
		"@types/node-cron": "^3.0.11",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-express": "^4.1.8",
		"@typescript-eslint/eslint-plugin": "^5.62.0",
		"@typescript-eslint/parser": "^5.62.0",
		"eslint": "^8.48.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-prettier": "^5.0.0",
		"nodemon": "^3.0.1",
		"prettier": "^3.0.3",
		"tsx": "^4.21.0"
	}
}
